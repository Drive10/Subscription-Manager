# Subscription Manager - Environment Configuration

# =============================================================================
# Database (for local development outside Docker)
# =============================================================================

DATABASE_URL=postgresql://subscription:changeme@subkeeper_db:5432/subscription_manager
POSTGRES_USER=subscription
POSTGRES_PASSWORD=changeme
POSTGRES_DB=subscription_manager

# =============================================================================
# Application
# =============================================================================

NODE_ENV=production
PORT=3001
BACKEND_PORT=3001
FRONTEND_PORT=3000

# =============================================================================
# Security
# =============================================================================

JWT_SECRET=your-super-secret-jwt-key-change-in-production

# =============================================================================
# Frontend URLs (local development - use localhost)
# For Docker, use container hostname: http://subkeeper_backend:3001
# =============================================================================

NEXT_PUBLIC_API_URL=http://subkeeper_backend:3001